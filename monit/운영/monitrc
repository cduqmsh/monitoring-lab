[ 인터페이스 감시 ]
# Public IP  
   check network public_eth0 with interface eth0
        if failed link then exec "/etc/monit/alert/monit2telegram.sh"
        else if succeeded then exec "/etc/monit/alert/monit2telegram.sh"

# Private IP
   check network private_eth1 with interface eth1
        if failed link then exec "/etc/monit/alert/monit2telegram.sh"
        else if succeeded then exec "/etc/monit/alert/monit2telegram.sh"

[ 프로세스 감시 ]
   check host [443Port]nginx address 1.1.1.1
        start program = "/usr/bin/systemctl start nginx"
        stop program  = "/usr/bin/systemctl stop nginx"
        if failed port 443 then restart
        if failed port 443 then exec "/etc/monit/alert/monit2telegram.sh"
        else if succeeded then exec "/etc/monit/alert/monit2telegram.sh"

   check host [3128Port]proxy_squid address 1.1.1.1
        start program = "/usr/bin/systemctl start squid"
        stop program  = "/usr/bin/systemctl stop squid"
        if failed port 3128 then restart
        if failed port 3128 then exec "/etc/monit/alert/monit2telegram.sh"
        else if succeeded then exec "/etc/monit/alert/monit2telegram.sh"

[ 어플리케이션 감시 ]
  check host [8280Port]springboot_jtbc-news-api-external with address 1.1.1.1
    if failed port 8280 for 10 cycles then exec "/etc/monit/alert/monit2telegram.sh"  # 5분 동안 포트 감지가 안될 경우
    else if succeeded then exec "/etc/monit/alert/monit2telegram.sh"

[ 메모리 감시 ]
   check file OutofMemory with path /var/log/kern.log
        if match "Out of memory" then exec "/etc/monit/alert/monit2telegram.sh"
